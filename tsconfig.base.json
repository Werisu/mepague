        "libs/historico/feature/src/index.ts"
      ],
      "@mepague/debtors-data-access": [
        "libs/debtors/data-access/src/index.ts"
      ],
      "@mepague/debtors-feature": [
        "libs/debtors/feature/src/index.ts"
      ],
      "@mepague/data-export": ["libs/data-export/src/index.ts"],
